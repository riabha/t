"""
Teacher CRUD + bulk CSV upload endpoints.
"""
from fastapi import APIRouter, Depends, HTTPException, UploadFile, File, Response
from fastapi.responses import StreamingResponse
from sqlalchemy.orm import Session, joinedload
from sqlalchemy import func, or_
from typing import List, Dict, Optional
import csv
import io
import pandas as pd
import re

from database import get_db
from models import Teacher, User, Assignment, AssignmentSession, TeacherDepartmentEngagement, Subject, Department
from auth import get_current_user
from schemas import TeacherCreate, TeacherOut
from auth import require_role, get_current_user, hash_password

def get_base_name(name: str) -> str:
    """Extra first name after skipping salutations like Prof., Dr., Engr."""
    parts = re.split(r'\s+', name.strip())
    salutations = {"prof", "dr", "engr", "mr", "ms", "mrs"}
    for p in parts:
        if p.strip(".").lower() not in salutations:
            return p
    return parts[0] if parts else "user"

DESIGNATION_MAX_HOURS = {
    "Professor": 6,
    "Associate Professor": 9,
    "Assistant Professor": 12,
    "Lecturer": 12,
    "Lab Engineer": 15,
    "Teaching Assistant": 15,
    "Jr. Lab Engineer": 15,
    "Lab Instructor": 15,
    "Lab Supervisor": 15,
}

router = APIRouter(prefix="/api/teachers", tags=["Teachers"])

@router.get("/", response_model=list[TeacherOut])
def list_teachers(department_id: int = None, session_id: int = None, db: Session = Depends(get_db), user=Depends(get_current_user)):
    # 1. Base Query with eager loading
    q = db.query(Teacher).options(
        joinedload(Teacher.department),
        joinedload(Teacher.user),
        joinedload(Teacher.engagements)
    )
    
    # Department filtering for program_admin
    if user.role == "program_admin" and not department_id:
        department_id = user.department_id
    
    if department_id:
        # Teachers who are in this dept OR engaged by this dept
        q = q.outerjoin(TeacherDepartmentEngagement).filter(
            or_(
                Teacher.department_id == department_id,
                TeacherDepartmentEngagement.department_id == department_id
            )
        )
    
    teachers = q.order_by(Teacher.name).all()

    if not teachers:
        return []

    teacher_ids = [t.id for t in teachers]

    # 2. Get active sessions
    active_sessions = db.query(AssignmentSession).filter(AssignmentSession.is_archived == False).all()
    active_session_ids = [s.id for s in active_sessions]
    
    # 3. Fetch all relevant assignments in one go
    all_asgn = db.query(Assignment).options(joinedload(Assignment.subject)).filter(
        (Assignment.teacher_id.in_(teacher_ids)) | (Assignment.lab_engineer_id.in_(teacher_ids)),
        Assignment.session_id.in_(active_session_ids)
    ).all()

    # 4. In-memory aggregation
    #    Theory hours → teacher, Lab hours → lab engineer.
    #    If the same person is both teacher & lab engineer, they get combined total.
    stats = {tid: {"current": 0.0, "global": 0.0, "current_theory": 0.0, "current_lab": 0.0} for tid in teacher_ids}

    for a in all_asgn:
        num_sec = len(a.section_ids) if a.section_ids else 0
        s = a.subject
        if not s: continue
        
        theory_load = float(s.theory_credits * num_sec)
        # Lab credits: each lab credit = 3 contact hours
        lab_hours = float(s.lab_credits * 3 * num_sec)
        lab_credits = float(s.lab_credits * num_sec) # Raw labs count

        is_current = (session_id == a.session_id) if session_id else True

        # Theory teacher gets theory hours
        if a.teacher_id in stats:
            stats[a.teacher_id]["global"] += theory_load
            if is_current:
                stats[a.teacher_id]["current"] += theory_load
                stats[a.teacher_id]["current_theory"] += theory_load
                
        # Lab engineer gets lab hours
        if a.lab_engineer_id in stats:
            stats[a.lab_engineer_id]["global"] += lab_hours
            if is_current:
                stats[a.lab_engineer_id]["current"] += lab_hours
                stats[a.lab_engineer_id]["current_lab"] += lab_credits

    # 5. Build results
    results = []
    for t in teachers:
        out = TeacherOut.model_validate(t)
        if t.user:
            out.username = t.user.username
            out.user_id = t.user.id
        if t.department:
            out.department_name = t.department.name
        
        t_stats = stats.get(t.id, {"current": 0.0, "global": 0.0, "current_theory": 0.0, "current_lab": 0.0})
        out.current_load = float(t_stats["current"])
        out.global_load = float(t_stats["global"])
        out.engaged_department_ids = [e.department_id for e in t.engagements]
        
        out_dict = out.model_dump()
        out_dict["current_theory_load"] = float(t_stats["current_theory"])
        out_dict["current_lab_load"] = float(t_stats["current_lab"])
        results.append(out_dict)

    return results



@router.post("/", response_model=TeacherOut)
def create_teacher(data: TeacherCreate, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    # Clerk/Program admin can only add teachers in their own department
    if user.role in ("clerk", "program_admin") and user.department_id:
        data = data.model_copy(update={"department_id": user.department_id})
    
    # Exclude non-model fields
    teacher_data = data.model_dump(exclude={"assign_account", "username", "password", "engaged_department_ids"})
    t = Teacher(**teacher_data)
    db.add(t)
    db.commit()
    db.refresh(t)

    # Handle Engagements
    for dept_id in data.engaged_department_ids:
        if dept_id != t.department_id:
            db.add(TeacherDepartmentEngagement(teacher_id=t.id, department_id=dept_id))
    db.commit()

    # Handle account creation
    if data.assign_account:
        raw_name = get_base_name(t.name)
        username = data.username or raw_name.lower()
        password = data.password or username
        
        # Ensure username uniqueness
        existing = db.query(User).filter(User.username == username).first()
        if existing:
            username = f"{username}_{t.id}"
            if not data.password:
                password = username

        new_user = User(
            username=username,
            password_hash=hash_password(password),
            full_name=t.name,
            role="teacher" if not t.is_lab_engineer else "lab_engineer",
            department_id=t.department_id,
            teacher_id=t.id
        )
        db.add(new_user)
        db.commit()
    
    # Reload for output
    db.refresh(t)
    u = db.query(User).filter(User.teacher_id == t.id).first()
    out = TeacherOut.model_validate(t)
    if u:
        out.username = u.username
        out.user_id = u.id
    out.engaged_department_ids = [e.department_id for e in t.engagements]
    return out


@router.post("/{teacher_id}/engage", response_model=TeacherOut)
def engage_teacher(teacher_id: int, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """Allow a department to engage a teacher from another department."""
    t = db.query(Teacher).filter(Teacher.id == teacher_id).first()
    if not t:
        raise HTTPException(404, "Teacher not found")
    
    dept_id = user.department_id
    if not dept_id and user.role != "super_admin":
         raise HTTPException(400, "User must belong to a department to engage faculty")
    
    # Check if already engaged or is home dept
    if t.department_id == dept_id:
        return t # Already home
    
    existing = db.query(TeacherDepartmentEngagement).filter(
        TeacherDepartmentEngagement.teacher_id == t.id,
        TeacherDepartmentEngagement.department_id == dept_id
    ).first()
    
    if not existing:
        db.add(TeacherDepartmentEngagement(teacher_id=t.id, department_id=dept_id))
        db.commit()
    
    db.refresh(t)
    out = TeacherOut.model_validate(t)
    out.engaged_department_ids = [e.department_id for e in t.engagements]
    return out


@router.post("/{teacher_id}/unengage", response_model=TeacherOut)
def unengage_teacher(teacher_id: int, db: Session = Depends(get_db),
                     user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """Allow a department to remove an engagement for a teacher."""
    t = db.query(Teacher).filter(Teacher.id == teacher_id).first()
    if not t:
        raise HTTPException(404, "Teacher not found")
    
    dept_id = user.department_id
    if not dept_id and user.role != "super_admin":
         raise HTTPException(400, "User must belong to a department to unengage faculty")
         
    if t.department_id == dept_id:
        raise HTTPException(400, "Cannot unengage a teacher from their home department")

    db.query(TeacherDepartmentEngagement).filter(
        TeacherDepartmentEngagement.teacher_id == t.id,
        TeacherDepartmentEngagement.department_id == dept_id
    ).delete()
    db.commit()
    
    db.refresh(t)
    out = TeacherOut.model_validate(t)
    out.engaged_department_ids = [e.department_id for e in t.engagements]
    return out


@router.put("/{teacher_id}", response_model=TeacherOut)
def update_teacher(teacher_id: int, data: TeacherCreate,
                   db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    t = db.query(Teacher).filter(Teacher.id == teacher_id).first()
    if not t:
        raise HTTPException(404, "Teacher not found")
    
    # Permission: ONLY primary department can update profile
    is_primary_dept = (user.role in ("super_admin", "program_admin")) or (user.role == "clerk" and t.department_id == user.department_id)
    
    if not is_primary_dept:
        # If guest dept, they can ONLY update engagements (e.g. adding themselves)
        # But for now let's just restrict full update to primary
        raise HTTPException(403, "Only the home department can modify this teacher's profile")

    if user.role in ("clerk", "program_admin") and user.department_id:
        data = data.model_copy(update={"department_id": user.department_id})
    
    # Update core attributes
    for k, v in data.model_dump(exclude={"assign_account", "username", "password", "engaged_department_ids"}).items():
        setattr(t, k, v)
    
    # Sync Engagements
    db.query(TeacherDepartmentEngagement).filter(TeacherDepartmentEngagement.teacher_id == t.id).delete()
    for dept_id in data.engaged_department_ids:
        if dept_id != t.department_id:
            db.add(TeacherDepartmentEngagement(teacher_id=t.id, department_id=dept_id))
    
    db.commit()

    # Manage Account
    existing_user = db.query(User).filter(User.teacher_id == t.id).first()
    if data.assign_account:
        if existing_user:
            if data.username: existing_user.username = data.username
            if data.password: existing_user.password_hash = hash_password(data.password)
            existing_user.full_name = t.name
            existing_user.role = "teacher" if not t.is_lab_engineer else "lab_engineer"
        else:
            raw_name = get_base_name(t.name)
            username = data.username or raw_name.lower()
            password = data.password or username
            
            if db.query(User).filter(User.username == username).first():
                username = f"{username}_{t.id}"
                if not data.password: password = username

            new_u = User(
                username=username,
                password_hash=hash_password(password),
                full_name=t.name,
                role="teacher" if not t.is_lab_engineer else "lab_engineer",
                department_id=t.department_id,
                teacher_id=t.id
            )
            db.add(new_u)
        db.commit()
    
    db.refresh(t)
    u = db.query(User).filter(User.teacher_id == t.id).first()
    out = TeacherOut.model_validate(t)
    if u:
        out.username = u.username
        out.user_id = u.id
    out.engaged_department_ids = [e.department_id for e in t.engagements]
    return out


@router.delete("/{teacher_id}")
def delete_teacher(teacher_id: int, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    t = db.query(Teacher).filter(Teacher.id == teacher_id).first()
    if not t:
        raise HTTPException(404, "Teacher not found")
    
    # Permission: ONLY primary department can delete
    if t.department_id != user.department_id and user.role != "super_admin":
        raise HTTPException(403, "Only the home department can delete this teacher")

    # Clear User account link if exists
    from models import User as UserModel, TimetableSlot
    db.query(UserModel).filter(UserModel.teacher_id == teacher_id).update({"teacher_id": None})
    # Null out TimetableSlot references
    db.query(TimetableSlot).filter(TimetableSlot.teacher_id == teacher_id).update({"teacher_id": None})
    db.query(TimetableSlot).filter(TimetableSlot.lab_engineer_id == teacher_id).update({"lab_engineer_id": None})

    db.delete(t)
    db.commit()
    return {"ok": True}


@router.get("/template")
def download_template(current_user = Depends(require_role("super_admin", "program_admin"))):
    """Return an Excel template for bulk teacher upload."""
    df = pd.DataFrame(columns=["name", "designation", "is_lab_engineer"])
    data = [
        {"name": "M. Riaz", "designation": "Professor", "is_lab_engineer": 0},
        {"name": "Ali Khan", "designation": "Lecturer", "is_lab_engineer": 0},
        {"name": "Sara Ahmed", "designation": "Lab Engineer", "is_lab_engineer": 1},
    ]
    df = pd.concat([df, pd.DataFrame(data)], ignore_index=True)
    
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        df.to_excel(writer, index=False, sheet_name='Teachers')
    output.seek(0)

    headers = {
        'Content-Disposition': 'attachment; filename="teacher_template.xlsx"'
    }
    return StreamingResponse(output, headers=headers, media_type='application/vnd.openxmlformats-officedocument.spreadsheetml.sheet')


@router.post("/upload")
async def upload_teachers(
    file: UploadFile = File(...),
    department_id: int = 1,
    db: Session = Depends(get_db),
    user=Depends(require_role("super_admin", "program_admin", "clerk")),
):
    """
    Bulk upload teachers from CSV or Excel.
    Expected columns: name, designation, is_lab_engineer (0/1 or True/False)
    Max contact hours auto-derived from designation.
    """
    filename = file.filename.lower()
    content = await file.read()
    
    try:
        if filename.endswith(".csv"):
            text = content.decode("utf-8-sig")
            df = pd.read_csv(io.StringIO(text))
        elif filename.endswith((".xlsx", ".xls")):
            df = pd.read_excel(io.BytesIO(content))
        else:
            raise HTTPException(400, "Unsupported file format. Use CSV or Excel.")
    except Exception as e:
        raise HTTPException(400, f"Error parsing file: {str(e)}")

    created = 0
    # Expected columns: ['name', 'designation', 'is_lab_engineer']
    # Normalize column names to lowercase
    df.columns = [c.lower().strip() for c in df.columns]
    
    for _, row in df.iterrows():
        name = str(row.get("name", "")).strip()
        if not name or name == "nan":
            continue
            
        designation = str(row.get("designation", "Lecturer")).strip()
        is_lab_val = str(row.get("is_lab_engineer", "0")).lower().strip()
        is_lab = is_lab_val in ("1", "true", "yes", "1.0")
        
        max_hours = DESIGNATION_MAX_HOURS.get(designation, 12)
        
        t = Teacher(
            name=name, designation=designation,
            max_contact_hours=max_hours,
            department_id=department_id,
            is_lab_engineer=is_lab,
        )
        db.add(t)
        db.flush() # Get the ID for account creation
        
        # Auto-create User account
        raw_name = get_base_name(name)
        username = raw_name.lower()
        password = username # Default password is the same as username
        
        # Ensure username uniqueness
        existing_u = db.query(User).filter(User.username == username).first()
        if existing_u:
            username = f"{username}_{t.id}"
            password = username
            
        new_u = User(
            username=username,
            password_hash=hash_password(password),
            full_name=name,
            role="teacher" if not is_lab else "lab_engineer",
            department_id=department_id,
            teacher_id=t.id
        )
        db.add(new_u)
        created += 1
        
    db.commit()
    return {"created": created, "message": f"Successfully imported {created} teachers."}
