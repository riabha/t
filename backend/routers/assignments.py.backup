"""
Assignment CRUD endpoints — links subjects to teachers, lab engineers, and sections.
"""
from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session, joinedload
from sqlalchemy import or_
from typing import Dict, Optional, List

from database import get_db
from models import Assignment, Subject, Teacher, Section, AssignmentSession, TeacherDepartmentEngagement, Batch
from schemas import (
    AssignmentCreate, AssignmentOut, AssignmentUpdate,
    AssignmentSessionCreate, AssignmentSessionOut, BulkSelector
)
from auth import require_role, get_current_user
from fastapi import UploadFile, File
import assignment_importer as importer
from schemas import ExtractedAssignmentOut, BulkImportRequest, BulkAssignmentGenerateRequest, BulkDeleteRequest
from fastapi.responses import StreamingResponse
import io

router = APIRouter(prefix="/api/assignments", tags=["Assignments"])

@router.get("/template")
def get_import_template(user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """Return a CSV template for assignment imports."""
    output = io.StringIO()
    # Headers based on assignment_importer.py expectations
    headers = [
        "Subject Name", "Course Code", "Theory Credits", "Lab Credits",
        "Teacher Name", "Lab Engineer", "Batch", "Sections"
    ]
    output.write(",".join(headers) + "\n")
    # Sample row
    sample = [
        "Data Structures", "CS-201", "3", "1",
        "Dr. John Doe", "Engr. Jane Smith", "BSCS-2", "A+B"
    ]
    output.write(",".join(sample) + "\n")
    
    output.seek(0)
    return StreamingResponse(
        output,
        media_type="text/csv",
        headers={"Content-Disposition": "attachment; filename=assignment_template.csv"}
    )


def _ensure_engagement(teacher_id: int, session_id: int, db: Session):
    """Ensure a teacher is engaged by the department of the session."""
    if not teacher_id:
        return
    session = db.query(AssignmentSession).filter(AssignmentSession.id == session_id).first()
    teacher = db.query(Teacher).filter(Teacher.id == teacher_id).first()
    if not session or not teacher:
        return
        
    dept_id = session.department_id
    if teacher.department_id == dept_id:
        return # Home dept
        
    existing = db.query(TeacherDepartmentEngagement).filter(
        TeacherDepartmentEngagement.teacher_id == teacher_id,
        TeacherDepartmentEngagement.department_id == dept_id
    ).first()
    if not existing:
        db.add(TeacherDepartmentEngagement(teacher_id=teacher_id, department_id=dept_id))
        db.flush()


def _enrich(a: Assignment, db: Session, sections_map: Dict[int, str] = None) -> AssignmentOut:
    section_names = []
    if a.section_ids:
        if sections_map is not None:
            section_names = [sections_map.get(sid, str(sid)) for sid in a.section_ids]
        else:
            secs = db.query(Section).filter(Section.id.in_(a.section_ids)).all()
            section_names = [s.display_name for s in secs]

    # Get department name from session, or fallback to batch's department
    dept_name = None
    if a.session and a.session.department:
        dept_name = a.session.department.name
    elif a.batch and a.batch.department:
        dept_name = a.batch.department.name

    return AssignmentOut(
        id=a.id,
        session_id=a.session_id,
        subject_id=a.subject_id,
        teacher_id=a.teacher_id,
        lab_engineer_id=a.lab_engineer_id,
        batch_id=a.batch_id,
        section_ids=a.section_ids or [],
        section_names=section_names,
        combination_id=a.combination_id,
        subject_code=a.subject.code if a.subject else None,
        subject_full_name=a.subject.full_name if a.subject else None,
        batch_name=a.batch.display_name if a.batch else None,
        teacher_name=a.teacher.name if a.teacher else None,
        lab_engineer_name=a.lab_engineer.name if a.lab_engineer else None,
        theory_credits=a.subject.theory_credits if a.subject else 0.0,
        lab_credits=a.subject.lab_credits if a.subject else 0.0,
        session_name=a.session.name if a.session else None,
        department_name=dept_name,
    )


# ── Sessions ────────────────────────────────────────────────────
@router.get("/sessions", response_model=list[AssignmentSessionOut])
def list_sessions(show_archived: bool = False, db: Session = Depends(get_db), user=Depends(get_current_user)):
    q = db.query(AssignmentSession)
    if user.role != "super_admin":
        q = q.filter(AssignmentSession.department_id == user.department_id)
    
    if not show_archived:
        q = q.filter(AssignmentSession.is_archived == False)
        
    return q.all()


@router.post("/sessions", response_model=AssignmentSessionOut)
def create_session(data: AssignmentSessionCreate, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    dept_id = data.department_id or user.department_id
    
    if not dept_id:
        raise HTTPException(400, "Department ID is required (especially for super admins)")
    
    if user.role != "super_admin" and dept_id != user.department_id:
        raise HTTPException(403, "Cannot create session for another department")
        
    s = AssignmentSession(name=data.name, department_id=dept_id)
    db.add(s)
    db.commit()
    db.refresh(s)
    return s


from schemas import AssignmentSessionUpdate

@router.put("/sessions/{session_id}", response_model=AssignmentSessionOut)
def update_session(session_id: int, data: AssignmentSessionUpdate, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    s = db.query(AssignmentSession).filter(AssignmentSession.id == session_id).first()
    if not s:
        raise HTTPException(404, "Session not found")
        
    if user.role != "super_admin" and s.department_id != user.department_id:
        raise HTTPException(403, "Access denied")
    
    update_data = data.model_dump(exclude_unset=True)
    for k, v in update_data.items():
        setattr(s, k, v)
        
    db.commit()
    db.refresh(s)
    return s


@router.delete("/sessions/{session_id}")
def delete_session(session_id: int, db: Session = Depends(get_db),
                   user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    s = db.query(AssignmentSession).filter(AssignmentSession.id == session_id).first()
    if not s:
        raise HTTPException(404, "Session not found")
    if user.role != "super_admin" and s.department_id != user.department_id:
        raise HTTPException(403, "Access denied")
    db.delete(s)
    db.commit()
    return {"ok": True}


from schemas import BulkSelector

@router.post("/sessions/bulk-delete")
def bulk_delete_sessions(data: BulkSelector, db: Session = Depends(get_db),
                         user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    q = db.query(AssignmentSession).filter(AssignmentSession.id.in_(data.ids))
    if user.role != "super_admin":
        q = q.filter(AssignmentSession.department_id == user.department_id)
    
    sessions = q.all()
    count = len(sessions)
    for s in sessions:
        db.delete(s)
    db.commit()
    return {"ok": True, "deleted_count": count}


@router.get("/", response_model=list[AssignmentOut])
def list_assignments(batch_id: int = None, session_id: int = None, teacher_id: int = None, 
                     db: Session = Depends(get_db), user=Depends(get_current_user)):
    # 1. Base query with eager loading of relationships
    q = db.query(Assignment).options(
        joinedload(Assignment.subject),
        joinedload(Assignment.teacher),
        joinedload(Assignment.lab_engineer),
        joinedload(Assignment.batch).joinedload(Batch.department)
    )
    
    if session_id:
        q = q.filter(Assignment.session_id == session_id)
    if batch_id:
        q = q.filter(Assignment.batch_id == batch_id)
    if teacher_id:
        q = q.filter(or_(Assignment.teacher_id == teacher_id, Assignment.lab_engineer_id == teacher_id))
    
    # Department Privacy
    if user.role not in ["super_admin", "program_admin"]:
        # Clerks and teachers can only see their own department
        q = q.join(AssignmentSession).filter(AssignmentSession.department_id == user.department_id)
    elif user.role == "program_admin":
        # Program admins can see cross-department assignments ONLY when viewing a specific teacher
        if not teacher_id:
            # If not viewing a specific teacher, filter by department
            q = q.join(AssignmentSession).filter(AssignmentSession.department_id == user.department_id)
        # If teacher_id is provided, don't filter by department (show all assignments for that teacher)
        
    assignments = q.all()
    
    # DEBUG LOGGING
    if teacher_id:
        print(f"\n=== ASSIGNMENTS ENDPOINT DEBUG ===")
        print(f"User: {user.username} (role: {user.role}, dept: {user.department_id})")
        print(f"Teacher ID filter: {teacher_id}")
        print(f"Assignments found: {len(assignments)}")
        for a in assignments:
            print(f"  - Assignment {a.id}: Session {a.session_id}, Subject {a.subject.code if a.subject else 'N/A'}")
        print(f"=== END DEBUG ===\n")
    
    if not assignments:
        return []

    # 2. Batch fetch all needed sections in one query
    all_section_ids = set()
    for a in assignments:
        if a.section_ids:
            all_section_ids.update(a.section_ids)
    
    sections_map = {}
    if all_section_ids:
        secs = db.query(Section).filter(Section.id.in_(list(all_section_ids))).all()
        sections_map = {s.id: s.display_name for s in secs}

    # 3. Enrich and return
    return [_enrich(a, db, sections_map) for a in assignments]


@router.post("/", response_model=AssignmentOut)
def create_assignment(data: AssignmentCreate, db: Session = Depends(get_db),
                      user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    a = Assignment(**data.model_dump())
    db.add(a)
    
    # Auto-engage
    _ensure_engagement(a.teacher_id, a.session_id, db)
    if a.lab_engineer_id:
        _ensure_engagement(a.lab_engineer_id, a.session_id, db)

    db.commit()
    db.refresh(a)
    return _enrich(a, db)


@router.put("/{assignment_id}", response_model=AssignmentOut)
def update_assignment(assignment_id: int, data: AssignmentUpdate, # Changed data type to AssignmentUpdate
                      db: Session = Depends(get_db),
                      user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    a = db.query(Assignment).filter(Assignment.id == assignment_id).first()
    if not a:
        raise HTTPException(404, "Assignment not found")
    
    update_data = data.model_dump(exclude_unset=True) # Modified update logic
    for k, v in update_data.items():
        setattr(a, k, v)
        
    db.commit()
    db.refresh(a)
    return _enrich(a, db)


@router.post("/bulk-combine")
def bulk_combine_assignments(data: BulkSelector, db: Session = Depends(get_db),
                             user=Depends(require_role("super_admin", "program_admin"))):
    assignments = db.query(Assignment).filter(Assignment.id.in_(data.ids)).all()
    if not assignments:
        return {"ok": False, "detail": "No assignments found"}
        
    import uuid
    comb_id = f"comb_{uuid.uuid4().hex[:8]}"
    
    for a in assignments:
        a.combination_id = comb_id
        
    db.commit()
    return {"ok": True, "combination_id": comb_id}


@router.post("/merge")
def merge_assignments(assignment_id: int, target_assignment_id: int, db: Session = Depends(get_db),
                      user=Depends(require_role("super_admin", "program_admin"))):
    a1 = db.query(Assignment).filter(Assignment.id == assignment_id).first()
    a2 = db.query(Assignment).filter(Assignment.id == target_assignment_id).first()
    if not a1 or not a2:
        raise HTTPException(404, "One or both assignments not found")

    # Use existing combination_id if present, otherwise create new
    comb_id = a1.combination_id or a2.combination_id
    if not comb_id:
        import uuid
        comb_id = f"comb_{uuid.uuid4().hex[:8]}"
    
    a1.combination_id = comb_id
    a2.combination_id = comb_id
    
    db.commit()
    return {"ok": True, "combination_id": comb_id}


@router.post("/mark-combined")
def mark_combined(assignment_id: int, join_combination_id: str = None, db: Session = Depends(get_db),
                  user=Depends(require_role("super_admin", "program_admin"))):
    """Mark a single assignment as combined. If join_combination_id is given, join that group."""
    a = db.query(Assignment).filter(Assignment.id == assignment_id).first()
    if not a:
        raise HTTPException(404, "Assignment not found")
    
    if join_combination_id:
        a.combination_id = join_combination_id
    elif not a.combination_id:
        import uuid
        a.combination_id = f"comb_{uuid.uuid4().hex[:8]}"
    
    db.commit()
    return {"ok": True, "combination_id": a.combination_id}


@router.post("/unmerge")
def unmerge_assignment(assignment_id: int, db: Session = Depends(get_db),
                       user=Depends(require_role("super_admin", "program_admin"))):
    a = db.query(Assignment).filter(Assignment.id == assignment_id).first()
    if not a:
        raise HTTPException(404, "Assignment not found")
    
    # Clear combination_id from ALL assignments in the same group
    if a.combination_id:
        siblings = db.query(Assignment).filter(
            Assignment.combination_id == a.combination_id
        ).all()
        for sib in siblings:
            sib.combination_id = None
    else:
        a.combination_id = None
    
    db.commit()
    return {"ok": True}

def _do_bulk_delete(ids: List[int], db: Session, user):
    from models import Assignment, Batch
    query = db.query(Assignment).filter(Assignment.id.in_(ids))
    
    if user.role != "super_admin":
        query = query.join(Batch).filter(Batch.department_id == user.department_id)
        
    targets = query.all()
    if not targets:
        return {"ok": True, "deleted_count": 0}
        
    count = 0
    for t in targets:
        db.delete(t)
        count += 1
        
    db.commit()
    return {"ok": True, "deleted_count": count}

@router.delete("/bulk")
def bulk_delete_assignments(data: BulkDeleteRequest, db: Session = Depends(get_db),
                            user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """Delete multiple assignments by ID (Legacy DELETE)."""
    return _do_bulk_delete(data.ids, db, user)

@router.post("/bulk-delete")
def bulk_delete_assignments_post(data: BulkDeleteRequest, db: Session = Depends(get_db),
                                 user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """Delete multiple assignments by ID (Robust POST)."""
    return _do_bulk_delete(data.ids, db, user)

@router.delete("/{assignment_id}")
def delete_assignment(assignment_id: int, db: Session = Depends(get_db),
                      user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    a = db.query(Assignment).filter(Assignment.id == assignment_id).first()
    if not a:
        raise HTTPException(404, "Assignment not found")
    db.delete(a)
    db.commit()
    return {"ok": True}

@router.post("/parse-import", response_model=list[ExtractedAssignmentOut])
async def parse_assignments_import(
    file: UploadFile = File(...),
    db: Session = Depends(get_db),
    user=Depends(require_role("super_admin", "program_admin", "clerk"))
):
    content = await file.read()
    filename = file.filename.lower()
    
    import_rows = []
    
    try:
        if filename.endswith(".pdf"):
            raw_text = importer.extract_from_pdf(content)
            import_rows = importer.parse_text_to_rows(raw_text)
        elif filename.endswith(".docx"):
            df = importer.extract_docx_tables(content)
            if df is not None and not df.empty:
                import_rows = importer.parse_dataframe(df)
            if not import_rows:
                raw_text = importer.extract_from_docx(content)
                import_rows = importer.parse_text_to_rows(raw_text)
        elif filename.endswith((".xlsx", ".xls", ".csv")):
            import pandas as import_pd
            import io as import_io
            if filename.endswith(".csv"):
                df = import_pd.read_csv(import_io.BytesIO(content))
            else:
                df = import_pd.read_excel(import_io.BytesIO(content))
            import_rows = importer.parse_dataframe(df)
    except Exception as e:
        import traceback
        print(f"DEBUG: File extraction failed: {e}")
        traceback.print_exc()
        raise HTTPException(status_code=400, detail=f"File extraction error: {str(e)}")

    if not import_rows:
         return []

    # Fetch all teachers, subjects, and batches for matching
    teachers = db.query(Teacher).all()
    subjects = db.query(Subject).all()
    
    from models import Batch
    batch_list = db.query(Batch).all()
    
    teacher_choices = [{"id": t.id, "name": t.name} for t in teachers]
    subject_choices = [{"id": s.id, "name": f"{s.code} - {s.full_name}"} for s in subjects]
    
    batch_choices = []
    for b in batch_list:
        try:
            name = b.display_name
        except Exception:
            name = f"Year {b.year} (ID:{b.id})"
        batch_choices.append({"id": b.id, "name": name})
    
    results = []
    for row in import_rows:
        try:
            obj = ExtractedAssignmentOut(**row)
            
            t_score = 0.0
            s_score = 0.0
            
            # Match Teacher
            raw_t = row.get("raw_teacher")
            if raw_t:
                t_match, t_score = importer.fuzzy_match_entity(raw_t, teacher_choices)
                if t_match:
                    obj.matched_teacher_id = t_match["id"]
                    obj.matched_teacher_name = t_match["name"]
                    
            # Match Subject
            raw_s = row.get("raw_subject")
            if raw_s:
                s_match, s_score = importer.fuzzy_match_entity(raw_s, subject_choices)
                if s_match:
                    obj.matched_subject_id = s_match["id"]
                    obj.matched_subject_name = s_match["name"]
                    
            # Match Lab Engineer
            raw_le = row.get("raw_lab_engineer")
            if raw_le:
                le_match, le_score = importer.fuzzy_match_entity(raw_le, teacher_choices)
                if le_match:
                    obj.matched_lab_engineer_id = le_match["id"]
                    obj.matched_lab_engineer_name = le_match["name"]
            
            # Match Batch (from raw_batch extracted by parser)
            raw_b = row.get("raw_batch")
            if raw_b and batch_choices:
                b_match, b_score = importer.fuzzy_match_entity(raw_b, batch_choices, threshold=50)
                if b_match:
                    obj.matched_batch_id = b_match["id"]
                    obj.matched_batch_name = b_match["name"]
            
            obj.confidence = (float(t_score) + float(s_score)) / 2.0
            results.append(obj)
        except Exception as e:
            print(f"DEBUG: Failed to process extracted row {row}: {e}")
            import traceback
            traceback.print_exc()
            continue
        
    return results



@router.post("/bulk-import")
def bulk_import_assignments(data: BulkImportRequest, db: Session = Depends(get_db),
                            user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    created = 0
    for entry in data.assignments:
        if not entry.matched_teacher_id or not entry.matched_subject_id:
            continue
            
        a = Assignment(
            session_id=data.session_id,
            batch_id=entry.matched_batch_id or data.batch_id,
            subject_id=entry.matched_subject_id,
            teacher_id=entry.matched_teacher_id,
            lab_engineer_id=entry.matched_lab_engineer_id,
            section_ids=[] # To be filled later
        )
        db.add(a)

        # Auto-engage
        _ensure_engagement(a.teacher_id, data.session_id, db)
        if a.lab_engineer_id:
            _ensure_engagement(a.lab_engineer_id, data.session_id, db)

        created += 1
        
    db.commit()
    return {"ok": True, "created_count": created}


@router.post("/bulk-generate")
def bulk_generate_assignments(data: BulkAssignmentGenerateRequest, db: Session = Depends(get_db),
                             user=Depends(require_role("super_admin", "program_admin", "clerk"))):
    """
    Generate placeholder assignments (teacher-less) for all subjects 
    in selected semesters for the given batches.
    """
    from models import Subject, Batch
    dept_id = user.department_id
    created_count = 0
    for bt in data.batch_terms:
        # 1. Fetch subjects for this specific term and department
        subjects_q = db.query(Subject).filter(Subject.semester == bt.semester)
        if user.role != "super_admin" and dept_id:
            subjects_q = subjects_q.filter(Subject.department_id == dept_id)
            
        subjects = subjects_q.all()
        if not subjects:
            continue
            
        # 2. Fetch batch and sections
        batch = db.query(Batch).filter(Batch.id == bt.batch_id).first()
        if not batch:
             continue
             
        # Create an assignment for each subject in this batch
        for s in subjects:
            if data.split_sections:
                for sec in batch.sections:
                    # Check if assignment already exists for THIS section
                    existing = db.query(Assignment).filter(
                        Assignment.session_id == data.session_id,
                        Assignment.subject_id == s.id,
                        Assignment.batch_id == batch.id,
                        Assignment.section_ids.contains([sec.id])
                    ).first()
                    
                    if existing:
                        continue

                    a = Assignment(
                        session_id=data.session_id,
                        subject_id=s.id,
                        batch_id=batch.id,
                        teacher_id=None,
                        section_ids=[sec.id]
                    )
                    db.add(a)
                    created_count += 1
            else:
                # Check if ANY assignment exists for this subject/batch
                existing = db.query(Assignment).filter(
                    Assignment.session_id == data.session_id,
                    Assignment.subject_id == s.id,
                    Assignment.batch_id == batch.id
                ).first()
                
                if existing:
                    continue

                a = Assignment(
                    session_id=data.session_id,
                    subject_id=s.id,
                    batch_id=batch.id,
                    teacher_id=None,
                    section_ids=[sec.id for sec in batch.sections]
                )
                db.add(a)
                created_count += 1
            
    db.commit()
    return {"ok": True, "created_count": created_count}
