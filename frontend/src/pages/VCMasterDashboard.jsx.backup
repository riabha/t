import React, { useState, useEffect } from 'react';
import { useAuth } from '../context/AuthContext';
import api from '../api';
import {
    HiOutlineAcademicCap, HiOutlineUserGroup, HiOutlineOfficeBuilding,
    HiOutlineCalendar, HiOutlineChartBar, HiOutlineClock,
    HiOutlineDownload, HiOutlineRefresh, HiOutlineEye
} from 'react-icons/hi';
import { jsPDF } from 'jspdf';
import autoTable from 'jspdf-autotable';

export default function VCMasterDashboard() {
    const { user } = useAuth();
    const [loading, setLoading] = useState(true);
    const [departments, setDepartments] = useState([]);
    const [timetables, setTimetables] = useState([]);
    const [teachers, setTeachers] = useState([]);
    const [subjects, setSubjects] = useState([]);
    const [rooms, setRooms] = useState([]);
    const [stats, setStats] = useState({});
    const [liveClasses, setLiveClasses] = useState([]);
    const [utilizationData, setUtilizationData] = useState([]);
    const [selectedView, setSelectedView] = useState('overview'); // 'overview', 'grid', 'timetables'
    const [selectedDepartment, setSelectedDepartment] = useState(null);
    const [departmentTimetables, setDepartmentTimetables] = useState({});
    const [heatmapData, setHeatmapData] = useState([]);

    useEffect(() => {
        loadData();
        // Refresh live data every minute
        const interval = setInterval(loadLiveData, 60000);
        return () => clearInterval(interval);
    }, []);

    useEffect(() => {
        if (departments.length > 0 && timetables.length > 0) {
            loadAllTimetables();
        }
    }, [departments, timetables]);

    const loadData = async () => {
        try {
            const [deptsRes, ttsRes, teachersRes, subjectsRes, roomsRes] = await Promise.all([
                api.get('/departments/'),
                api.get('/timetable/list'),
                api.get('/teachers/'),
                api.get('/subjects/'),
                api.get('/rooms/')
            ]);

            setDepartments(deptsRes.data);
            setTimetables(ttsRes.data);
            setTeachers(teachersRes.data);
            setSubjects(subjectsRes.data);
            setRooms(roomsRes.data);

            calculateStats(deptsRes.data, ttsRes.data, teachersRes.data, subjectsRes.data, roomsRes.data);
            await loadLiveData();
        } catch (err) {
            console.error('Failed to load data:', err);
        }
        setLoading(false);
    };

    const loadLiveData = async () => {
        try {
            // Get current time slot
            const { day, slot } = getCurrentDayAndSlot();
            
            if (day === null || slot === null) {
                setLiveClasses([]);
                return;
            }

            // Get all active timetables
            const activeTTs = timetables.filter(t => t.status === 'active' || t.status === 'generated');
            
            const allClasses = [];
            for (const tt of activeTTs) {
                try {
                    const res = await api.get(`/timetable/${tt.id}`);
                    const slots = res.data.slots || [];
                    
                    // Filter current classes
                    const currentSlots = slots.filter(s => 
                        s.day === day && 
                        s.slot_index === slot && 
                        !s.is_break
                    );

                    currentSlots.forEach(s => {
                        allClasses.push({
                            ...s,
                            timetable_name: tt.name,
                            department_name: departments.find(d => d.id === tt.department_id)?.name
                        });
                    });
                } catch (err) {
                    console.error(`Failed to load timetable ${tt.id}:`, err);
                }
            }

            setLiveClasses(allClasses);
            calculateUtilization(allClasses);
        } catch (err) {
            console.error('Failed to load live data:', err);
        }
    };

    const getCurrentDayAndSlot = () => {
        const now = new Date();
        const dayOfWeek = now.getDay();
        let dayIndex = dayOfWeek - 1;
        
        if (dayIndex < 0 || dayIndex > 4) {
            return { day: null, slot: null };
        }

        const currentMinutes = now.getHours() * 60 + now.getMinutes();
        const startMinutes = 8 * 60 + 30; // 8:30 AM
        const classDuration = 60;

        if (currentMinutes < startMinutes) {
            return { day: dayIndex, slot: null };
        }

        const slotIndex = Math.floor((currentMinutes - startMinutes) / classDuration);
        
        if (slotIndex >= 8) {
            return { day: dayIndex, slot: null };
        }

        return { day: dayIndex, slot: slotIndex };
    };

    const calculateStats = (depts, tts, teachers, subjects, rooms) => {
        const activeTTs = tts.filter(t => t.status === 'active' || t.status === 'generated');
        
        setStats({
            totalDepartments: depts.length,
            totalTeachers: teachers.filter(t => !t.is_lab_engineer).length,
            totalLabEngineers: teachers.filter(t => t.is_lab_engineer).length,
            totalSubjects: subjects.length,
            totalRooms: rooms.length,
            activeTimetables: activeTTs.length,
            archivedTimetables: tts.filter(t => t.status === 'archived').length
        });
    };

    const calculateUtilization = (classes) => {
        const deptUtilization = {};
        
        departments.forEach(dept => {
            const deptClasses = classes.filter(c => c.department_name === dept.name);
            const deptRooms = rooms.filter(r => r.department_id === dept.id);
            
            const occupiedRooms = new Set(deptClasses.map(c => c.room_id).filter(Boolean));
            const utilization = deptRooms.length > 0 
                ? (occupiedRooms.size / deptRooms.length) * 100 
                : 0;

            deptUtilization[dept.name] = {
                total: deptClasses.length,
                rooms: deptRooms.length,
                occupied: occupiedRooms.size,
                utilization: Math.round(utilization)
            };
        });

        setUtilizationData(Object.entries(deptUtilization));
    };

    const loadAllTimetables = async () => {
        const ttData = {};
        const heatmap = [];

        for (const dept of departments) {
            // Find active or latest timetable for this department
            const deptTTs = timetables.filter(t => t.department_id === dept.id);
            const activeTT = deptTTs.find(t => t.status === 'active') || 
                            deptTTs.find(t => t.status === 'generated') ||
                            deptTTs[0];

            if (activeTT) {
                try {
                    const res = await api.get(`/timetable/${activeTT.id}`);
                    ttData[dept.id] = {
                        ...activeTT,
                        slots: res.data.slots || [],
                        sections: res.data.sections || []
                    };

                    // Calculate heatmap data for this department
                    const slots = res.data.slots || [];
                    const slotUtilization = Array(5).fill(null).map(() => Array(8).fill(0));
                    
                    slots.forEach(slot => {
                        if (!slot.is_break && slot.day >= 0 && slot.day < 5 && slot.slot_index >= 0 && slot.slot_index < 8) {
                            slotUtilization[slot.day][slot.slot_index]++;
                        }
                    });

                    heatmap.push({
                        deptId: dept.id,
                        deptName: dept.name,
                        deptCode: dept.code,
                        utilization: slotUtilization,
                        totalClasses: slots.filter(s => !s.is_break).length
                    });
                } catch (err) {
                    console.error(`Failed to load timetable for ${dept.name}:`, err);
                }
            }
        }

        setDepartmentTimetables(ttData);
        setHeatmapData(heatmap);
    };

    const exportMasterPDF = async () => {
        try {
            const doc = new jsPDF({
                orientation: 'landscape',
                unit: 'mm',
                format: 'a4'
            });

            // Title Page
            doc.setFontSize(24);
            doc.setFont(undefined, 'bold');
            doc.text('QUEST University', 148, 40, { align: 'center' });
            doc.setFontSize(18);
            doc.text('Master Timetable Report', 148, 50, { align: 'center' });
            doc.setFontSize(12);
            doc.setFont(undefined, 'normal');
            doc.text(`Generated: ${new Date().toLocaleString()}`, 148, 60, { align: 'center' });
            doc.text(`Generated by: ${user?.full_name || user?.username}`, 148, 67, { align: 'center' });

            // Summary Stats
            doc.addPage();
            doc.setFontSize(16);
            doc.setFont(undefined, 'bold');
            doc.text('University Statistics', 14, 20);

            const statsData = [
                ['Metric', 'Count'],
                ['Total Departments', stats.totalDepartments],
                ['Faculty Members', stats.totalTeachers],
                ['Lab Engineers', stats.totalLabEngineers],
                ['Total Subjects', stats.totalSubjects],
                ['Total Rooms', stats.totalRooms],
                ['Active Timetables', stats.activeTimetables],
                ['Archived Timetables', stats.archivedTimetables]
            ];

            autoTable(doc, {
                head: [statsData[0]],
                body: statsData.slice(1),
                startY: 30,
                theme: 'grid',
                headStyles: { fillColor: [71, 85, 105] }
            });

            // Department-wise breakdown
            doc.addPage();
            doc.setFontSize(16);
            doc.text('Department-wise Breakdown', 14, 20);

            const deptData = departments.map(dept => {
                const deptTeachers = teachers.filter(t => t.department_id === dept.id && !t.is_lab_engineer);
                const deptSubjects = subjects.filter(s => s.department_id === dept.id);
                const deptRooms = rooms.filter(r => r.department_id === dept.id);
                
                return [
                    dept.name,
                    dept.code,
                    deptTeachers.length,
                    deptSubjects.length,
                    deptRooms.length
                ];
            });

            autoTable(doc, {
                head: [['Department', 'Code', 'Faculty', 'Subjects', 'Rooms']],
                body: deptData,
                startY: 30,
                theme: 'striped',
                headStyles: { fillColor: [71, 85, 105] }
            });

            // Save
            doc.save(`QUEST_Master_Timetable_${new Date().toISOString().split('T')[0]}.pdf`);
        } catch (err) {
            console.error('PDF export failed:', err);
            alert('Failed to generate PDF');
        }
    };

    const getUtilizationColor = (percentage) => {
        if (percentage >= 80) return 'bg-red-500';
        if (percentage >= 60) return 'bg-amber-500';
        if (percentage >= 40) return 'bg-blue-500';
        return 'bg-emerald-500';
    };

    const getUtilizationLabel = (percentage) => {
        if (percentage >= 80) return 'High';
        if (percentage >= 60) return 'Moderate';
        if (percentage >= 40) return 'Low';
        return 'Very Low';
    };

    const getHeatmapColor = (count) => {
        if (count === 0) return 'bg-slate-100';
        if (count <= 2) return 'bg-emerald-200';
        if (count <= 4) return 'bg-blue-300';
        if (count <= 6) return 'bg-amber-400';
        return 'bg-red-500';
    };

    const getDayName = (index) => {
        return ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'][index];
    };

    const getSlotTime = (index) => {
        const startHour = 8;
        const startMinute = 30;
        const hour = startHour + Math.floor((startMinute + index * 60) / 60);
        const minute = (startMinute + index * 60) % 60;
        return `${hour}:${minute.toString().padStart(2, '0')}`;
    };

    if (loading) {
        return (
            <div className="flex items-center justify-center h-screen">
                <div className="text-center">
                    <div className="w-16 h-16 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mx-auto mb-4" />
                    <p className="text-slate-600">Loading Master Dashboard...</p>
                </div>
            </div>
        );
    }

    const totalUtilization = utilizationData.length > 0
        ? Math.round(utilizationData.reduce((sum, [_, data]) => sum + data.utilization, 0) / utilizationData.length)
        : 0;

    return (
        <div className="space-y-6">
            {/* Header with View Tabs */}
            <div className="flex items-center justify-between">
                <div>
                    <h1 className="text-2xl font-bold text-slate-800 flex items-center gap-3">
                        <span className="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white">
                            <HiOutlineChartBar className="w-6 h-6" />
                        </span>
                        VC Master Dashboard
                    </h1>
                    <p className="text-sm text-slate-500 mt-1">University-wide overview and analytics</p>
                </div>
                <div className="flex gap-3">
                    <button
                        onClick={loadLiveData}
                        className="flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                        <HiOutlineRefresh className="w-4 h-4" />
                        Refresh
                    </button>
                    <button
                        onClick={exportMasterPDF}
                        className="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white rounded-lg hover:shadow-lg transition-all">
                        <HiOutlineDownload className="w-4 h-4" />
                        Export PDF
                    </button>
                </div>
            </div>

            {/* View Tabs */}
            <div className="flex gap-2 border-b border-slate-200">
                <button
                    onClick={() => setSelectedView('overview')}
                    className={`px-6 py-3 font-medium text-sm transition-all ${
                        selectedView === 'overview'
                            ? 'text-blue-600 border-b-2 border-blue-600'
                            : 'text-slate-500 hover:text-slate-700'
                    }`}>
                    Overview
                </button>
                <button
                    onClick={() => setSelectedView('grid')}
                    className={`px-6 py-3 font-medium text-sm transition-all ${
                        selectedView === 'grid'
                            ? 'text-blue-600 border-b-2 border-blue-600'
                            : 'text-slate-500 hover:text-slate-700'
                    }`}>
                    University Grid
                </button>
                <button
                    onClick={() => setSelectedView('timetables')}
                    className={`px-6 py-3 font-medium text-sm transition-all ${
                        selectedView === 'timetables'
                            ? 'text-blue-600 border-b-2 border-blue-600'
                            : 'text-slate-500 hover:text-slate-700'
                    }`}>
                    Department Timetables
                </button>
            </div>

            {/* Stats Grid */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div className="glass p-5 rounded-xl border border-blue-200">
                    <div className="flex items-center justify-between mb-2">
                        <HiOutlineOfficeBuilding className="w-8 h-8 text-blue-600" />
                        <span className="text-3xl font-bold text-blue-600">{stats.totalDepartments}</span>
                    </div>
                    <p className="text-sm font-medium text-slate-600">Departments</p>
                </div>

                <div className="glass p-5 rounded-xl border border-emerald-200">
                    <div className="flex items-center justify-between mb-2">
                        <HiOutlineUserGroup className="w-8 h-8 text-emerald-600" />
                        <span className="text-3xl font-bold text-emerald-600">{stats.totalTeachers}</span>
                    </div>
                    <p className="text-sm font-medium text-slate-600">Faculty Members</p>
                </div>

                <div className="glass p-5 rounded-xl border border-violet-200">
                    <div className="flex items-center justify-between mb-2">
                        <HiOutlineAcademicCap className="w-8 h-8 text-violet-600" />
                        <span className="text-3xl font-bold text-violet-600">{stats.totalSubjects}</span>
                    </div>
                    <p className="text-sm font-medium text-slate-600">Total Subjects</p>
                </div>

                <div className="glass p-5 rounded-xl border border-amber-200">
                    <div className="flex items-center justify-between mb-2">
                        <HiOutlineCalendar className="w-8 h-8 text-amber-600" />
                        <span className="text-3xl font-bold text-amber-600">{stats.activeTimetables}</span>
                    </div>
                    <p className="text-sm font-medium text-slate-600">Active Timetables</p>
                </div>
            </div>

            {/* Live Status */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                {/* Current Utilization */}
                <div className="lg:col-span-2 glass p-6 rounded-xl">
                    <div className="flex items-center justify-between mb-4">
                        <h2 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                            <HiOutlineClock className="w-5 h-5 text-blue-600" />
                            Live University Status
                        </h2>
                        <span className="flex items-center gap-2 text-sm">
                            <span className="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                            {new Date().toLocaleTimeString()}
                        </span>
                    </div>

                    <div className="mb-6">
                        <div className="flex items-center justify-between mb-2">
                            <span className="text-sm font-medium text-slate-600">Overall Utilization</span>
                            <span className="text-2xl font-bold text-slate-800">{totalUtilization}%</span>
                        </div>
                        <div className="w-full h-4 bg-slate-200 rounded-full overflow-hidden">
                            <div 
                                className={`h-full ${getUtilizationColor(totalUtilization)} transition-all duration-500`}
                                style={{ width: `${totalUtilization}%` }}
                            />
                        </div>
                        <p className="text-xs text-slate-500 mt-1">
                            {liveClasses.length} classes in progress across {departments.length} departments
                        </p>
                    </div>

                    {/* Department Utilization */}
                    <div className="space-y-3">
                        {utilizationData.map(([deptName, data]) => (
                            <div key={deptName} className="flex items-center gap-3">
                                <div className="flex-1">
                                    <div className="flex items-center justify-between mb-1">
                                        <span className="text-sm font-medium text-slate-700">{deptName}</span>
                                        <span className="text-xs text-slate-500">
                                            {data.occupied}/{data.rooms} rooms • {data.total} classes
                                        </span>
                                    </div>
                                    <div className="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                                        <div 
                                            className={`h-full ${getUtilizationColor(data.utilization)} transition-all`}
                                            style={{ width: `${data.utilization}%` }}
                                        />
                                    </div>
                                </div>
                                <span className={`px-2 py-1 rounded text-xs font-bold ${
                                    data.utilization >= 80 ? 'bg-red-100 text-red-700' :
                                    data.utilization >= 60 ? 'bg-amber-100 text-amber-700' :
                                    data.utilization >= 40 ? 'bg-blue-100 text-blue-700' :
                                    'bg-emerald-100 text-emerald-700'
                                }`}>
                                    {data.utilization}%
                                </span>
                            </div>
                        ))}
                    </div>
                </div>

                {/* Quick Actions */}
                <div className="glass p-6 rounded-xl">
                    <h2 className="text-lg font-bold text-slate-800 mb-4">Quick Actions</h2>
                    <div className="space-y-3">
                        <a
                            href="/dashboard/timetable"
                            className="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow-md transition-all">
                            <HiOutlineCalendar className="w-5 h-5 text-blue-600" />
                            <div>
                                <p className="font-medium text-sm text-slate-800">View Timetables</p>
                                <p className="text-xs text-slate-500">All department schedules</p>
                            </div>
                        </a>

                        <a
                            href="/dashboard/teachers"
                            className="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:border-emerald-300 hover:shadow-md transition-all">
                            <HiOutlineUserGroup className="w-5 h-5 text-emerald-600" />
                            <div>
                                <p className="font-medium text-sm text-slate-800">Faculty Management</p>
                                <p className="text-xs text-slate-500">Manage teachers & staff</p>
                            </div>
                        </a>

                        <a
                            href="/dashboard/departments"
                            className="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:border-violet-300 hover:shadow-md transition-all">
                            <HiOutlineOfficeBuilding className="w-5 h-5 text-violet-600" />
                            <div>
                                <p className="font-medium text-sm text-slate-800">Departments</p>
                                <p className="text-xs text-slate-500">Department settings</p>
                            </div>
                        </a>

                        <a
                            href="/"
                            target="_blank"
                            className="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:border-amber-300 hover:shadow-md transition-all">
                            <HiOutlineEye className="w-5 h-5 text-amber-600" />
                            <div>
                                <p className="font-medium text-sm text-slate-800">Public View</p>
                                <p className="text-xs text-slate-500">Student portal</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            {/* Live Classes */}
            <div className="glass p-6 rounded-xl">
                <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <span className="w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
                    Classes Happening Now ({liveClasses.length})
                </h2>
                
                {liveClasses.length > 0 ? (
                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {liveClasses.slice(0, 12).map((cls, idx) => (
                            <div key={idx} className="bg-white rounded-lg border border-slate-200 p-4 hover:shadow-md transition-shadow">
                                <div className="flex items-start justify-between mb-2">
                                    <h3 className="font-bold text-slate-800">{cls.subject_code}</h3>
                                    {cls.is_lab && (
                                        <span className="px-2 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-bold rounded">
                                            Lab
                                        </span>
                                    )}
                                </div>
                                <div className="space-y-1 text-sm text-slate-600">
                                    <p><span className="font-medium">Section:</span> {cls.section_name}</p>
                                    <p><span className="font-medium">Teacher:</span> {cls.teacher_name || cls.lab_engineer_name}</p>
                                    <p><span className="font-medium">Room:</span> {cls.room_name || 'TBA'}</p>
                                    <p className="text-xs text-slate-500">{cls.department_name}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div className="text-center py-12 text-slate-500">
                        <HiOutlineClock className="w-12 h-12 mx-auto mb-3 opacity-50" />
                        <p>No classes in progress at this time</p>
                    </div>
                )}
            </div>
        </div>
    );
}
